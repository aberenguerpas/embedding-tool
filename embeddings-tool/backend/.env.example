# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated list of allowed sentence-transformers model IDs
ST_ALLOWED_MODELS=sentence-transformers/all-MiniLM-L6-v2,sentence-transformers/all-mpnet-base-v2,sentence-transformers/all-distilroberta-v1,sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2,sentence-transformers/paraphrase-multilingual-mpnet-base-v2,sentence-transformers/distiluse-base-multilingual-cased-v2,sentence-transformers/LaBSE,sentence-transformers/multi-qa-mpnet-base-dot-v1,sentence-transformers/multi-qa-MiniLM-L6-cos-v1,sentence-transformers/msmarco-distilbert-base-v4,sentence-transformers/msmarco-MiniLM-L6-cos-v5,google/embeddinggemma-300m
ST_ALLOWED_RERANKERS=cross-encoder/ms-marco-MiniLM-L-6-v2,BAAI/bge-reranker-base,mixedbread-ai/mxbai-rerank-base-v1

# If true, allows downloading any model ID received in requests
ST_ALLOW_DYNAMIC_MODELS=true
ST_ALLOW_DYNAMIC_RERANKERS=true

# If true, preload all models from ST_ALLOWED_MODELS at startup
ST_PRELOAD_ON_STARTUP=false
ST_PRELOAD_RERANKERS_ON_STARTUP=false

# sentence-transformers encode config
ST_DEVICE=cpu
ST_CACHE_DIR=
ST_BATCH_SIZE=32

# Comma-separated CORS origins
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
